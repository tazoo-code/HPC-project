Bootstrap: docker
From: nvidia/cuda:11.8.0-cudnn8-devel-ubuntu22.04

%labels
    Author      HPC Course Project
    Description Age Progression with Stable Diffusion + LoRA
    Version     1.0

%post
    # Avoid interactive prompts
    export DEBIAN_FRONTEND=noninteractive

    # System dependencies
    apt-get update && apt-get install -y \
        python3 \
        python3-pip \
        python3-dev \
        git \
        wget \
        libgl1-mesa-glx \
        libglib2.0-0 \
        && rm -rf /var/lib/apt/lists/*

    # Make python3 the default
    ln -sf /usr/bin/python3 /usr/bin/python

    # Upgrade pip
    pip install --upgrade pip

    # PyTorch with CUDA 11.8
    pip install torch==2.1.0 torchvision==0.16.0 --index-url https://download.pytorch.org/whl/cu118

    # HuggingFace stack
    pip install \
        diffusers==0.27.0 \
        transformers==4.38.0 \
        accelerate==0.27.0 \
        datasets==2.18.0 \
        huggingface_hub==0.21.0 \
        peft==0.9.0

    # Training utilities
    pip install \
        Pillow==10.2.0 \
        numpy==1.26.4 \
        pandas==2.2.1 \
        tqdm==4.66.2 \
        xformers==0.0.23 \
        bitsandbytes==0.42.0

    # Evaluation metrics
    pip install \
        torch-fidelity==0.3.0 \
        facenet-pytorch==2.5.3 \
        scikit-learn==1.4.1

    # Download the LoRA training script from diffusers
    mkdir -p /opt/diffusers_scripts
    wget -q https://raw.githubusercontent.com/huggingface/diffusers/v0.27.0/examples/text_to_image/train_text_to_image_lora.py \
         -O /opt/diffusers_scripts/train_text_to_image_lora.py

    # Clean pip cache
    pip cache purge

%environment
    export PYTHONUNBUFFERED=1
    export TRANSFORMERS_CACHE=/tmp/hf_cache
    export HF_HOME=/tmp/hf_cache
    # Suppress tokenizer parallelism warnings
    export TOKENIZERS_PARALLELISM=false

%runscript
    exec python "$@"

%help
    Container for age progression fine-tuning with SD 1.5 + LoRA.

    Usage examples:
        # Run preprocessing
        singularity exec --nv age_diffusion.sif python /project/scripts/preprocess.py ...

        # Run training
        singularity exec --nv age_diffusion.sif accelerate launch /opt/diffusers_scripts/train_text_to_image_lora.py ...

        # Run inference
        singularity exec --nv age_diffusion.sif python /project/scripts/inference.py ...
